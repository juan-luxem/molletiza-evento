---
import Layout from '../layouts/Layout.astro';
import LoginForm from '../components/LoginForm';
---

<Layout title="Entrar — Molletiza">
  <main class="min-h-screen bg-[#FFFCF5] flex">

    <!-- Panel izquierdo decorativo (solo desktop) -->
    <div class="hidden lg:flex lg:w-[42%] bg-amber-600 flex-col justify-between p-12 relative overflow-hidden">
      <!-- Texture dots -->
      <div class="absolute inset-0 opacity-10"
        style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 24px 24px;">
      </div>

      <a href="/" class="relative z-10 flex items-center gap-2.5">
        <span class="text-2xl">🫓</span>
        <span class="text-white font-semibold tracking-tight">Molletiza</span>
      </a>

      <div class="relative z-10">
        <p class="text-amber-100 text-4xl font-semibold leading-tight mb-6">
          "El queso<br />no se detiene."
        </p>
        <div class="flex flex-col gap-3">
          <div class="flex items-center gap-3 text-amber-100">
            <span class="w-8 h-8 rounded-xl bg-amber-500/50 flex items-center justify-center text-base">🎡</span>
            <span class="text-sm">Gira la ruleta y descubre tu ingrediente</span>
          </div>
          <div class="flex items-center gap-3 text-amber-100">
            <span class="w-8 h-8 rounded-xl bg-amber-500/50 flex items-center justify-center text-base">📅</span>
            <span class="text-sm">Vota por la fecha que más te late</span>
          </div>
          <div class="flex items-center gap-3 text-amber-100">
            <span class="w-8 h-8 rounded-xl bg-amber-500/50 flex items-center justify-center text-base">🧾</span>
            <span class="text-sm">Ve el menú y las cantidades del día</span>
          </div>
        </div>
      </div>

      <p class="relative z-10 text-amber-300 text-xs">Solo para los 27 afortunados 🫓</p>
    </div>

    <!-- Panel de login -->
    <div class="flex-1 flex items-center justify-center px-6 py-12">
      <div class="w-full max-w-sm">

        <!-- Back link (mobile) -->
        <a href="/" class="lg:hidden inline-flex items-center gap-1.5 text-sm text-stone-400 hover:text-stone-600 transition-colors mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          Volver al inicio
        </a>

        <div class="mb-8">
          <div class="w-12 h-12 rounded-2xl bg-amber-100 border border-amber-200 flex items-center justify-center text-2xl mb-5 shadow-sm">
            🫓
          </div>
          <h1 class="text-2xl font-semibold text-stone-900 tracking-tight">Bienvenido de vuelta</h1>
          <p class="text-stone-400 mt-1 text-sm">Entra con tu correo de Molletiza</p>
        </div>

        <LoginForm client:load />

      </div>
    </div>

  </main>
</Layout>
